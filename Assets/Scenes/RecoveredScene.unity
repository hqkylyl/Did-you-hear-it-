  storyText: "\u62DB\u5A23\u62DB\u5A23\uFF0C\u6211\u4E0D\u559C\u6B22\u8FD9\u4E2A\u540D\u5B57\uFF0C\u5B83\u627F\u8F7D\u7684\u662F\u5BF9\u522B\u4EBA\u7684\u671F\u5F85\uFF0C\u4E0D\u662F\u6211\u7684\u3002\u5982\u679C\u88AB\u7231\u662F\u53D8\u6210\u53EA\u4F1A\u6253\u67B6\u548C\u4E0D\u5B66\u65E0\u672F\u7684\u7537\u751F\uFF0C\u90A3\u6211\u8FD8\u662F\u4E0D\u8981\u4ED6\u4EEC\u7231\u6211\u4E86\u3002\n\u7B49\u6211\u957F\u5927\u4E86\uFF0C\u6211\u4E00\u5B9A\u8981\u53BB\u6539\u540D\uFF0C\u6539\u4E00\u4E2A\u627F\u8F7D\u7740\u6211\u81EA\u5DF1\u5BF9\u81EA\u5DF1\u7684\u671F\u5F85\uFF0C\u8981\u4E0D\u5C31\u53EB\u5411\u9633\u5427\uFF1F\u53CD\u6B63\u8001\u5E08\u548C\u540C\u5B66\u4EEC\u90FD\u8BF4\u6211\u50CF\u4E2A\u5C0F\u592A\u9633"
