  storyText: "\u4ECA\u5929\u5BA2\u5385\u7684\u949F\u8D70\u4E86\u597D\u4E45\uFF0C\u6EF4\u7B54\u6EF4\u7B54\u7684\uFF0C\u542C\u5F97\u6211\u5934\u75BC\u3002\u6BCD\u4EB2\u53C8\u5728\u53EB\u6211\u6253\u626B\u536B\u751F\u4E86\uFF0C\u73A9\u5177\u3001\u9152\u74F6\u3001\u6EE1\u5730\u7684\u7EB8\u5C51...\n\n\u6211\u5F88\u7FA1\u6155\u5F1F\u5F1F\uFF0C\u4ED6\u4E00\u51FA\u751F\u5C31\u5907\u53D7\u5BA0\u7231\u3002\u5168\u5BB6\u798F\u91CC\uFF0C\u7236\u4EB2\u7B11\u7684\u5F88\u5F00\u5FC3\u3002\u5370\u8C61\u91CC\uFF0C\u597D\u50CF\u4ED6\u4EEC\u4ECE\u6CA1\u6709\u5BF9\u5F1F\u5F1F\u751F\u6C14\u8FC7\uFF0C\u4E00\u76F4\u90FD\u662F\u548C\u989C\u60A6\u8272\u7684\u3002\n\u771F\u597D\u554A\u3002\n\u4F46\u662F\u4E00\u5B9A\u8981\u6210\u4E3A\u7537\u751F\u624D\u53EF\u4EE5\u8FD9\u6837\u88AB\u4ED6\u4EEC\u7231\u5417\uFF1F\n"
