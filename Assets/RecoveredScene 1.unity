  indentLevel: 1
  storyText: "202X\u5E74 4\u670812\u65E5 \u6674\n\n\u4ECA\u5929\u8001\u5E08\u5728\u73ED\u4E0A\u5938\u6211\u4F5C\u6587\u5199\u5F97\u597D\uFF0C\u9898\u76EE\u662F\u300A\u6211\u7684\u5BB6\u300B\u3002\u6211\u5199\u4E86\u5988\u5988\u7F1D\u8865\u8863\u670D\u7684\u6837\u5B50\uFF0C\u8FD8\u6709\u7238\u7238\u4E0B\u73ED\u5E26\u56DE\u6765\u7684\u7EA2\u85AF\u3002\u867D\u7136\u7238\u7238\u603B\u662F\u76B1\u7740\u7709\u5934\uFF0C\u4F46\u6211\u628A\u7EA2\u85AF\u5206\u7ED9\u4ED6\u4E00\u534A\u7684\u65F6\u5019\uFF0C\u4ED6\u6478\u4E86\u6478\u6211\u7684\u5934\u3002\n\u6211\u603B\u89C9\u5F97\uFF0C\u53EA\u8981\u6211\u505A\u5F97\u8DB3\u591F\u597D\uFF0C\u8DB3\u591F\u542C\u8BDD\uFF0C\u7238\u7238\u5988\u5988\u5C31\u4F1A\u4E00\u76F4\u50CF\u4ECA\u5929\u8FD9\u6837\u5BF9\u6211\u7B11\u3002"
